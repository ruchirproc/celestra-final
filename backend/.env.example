# Azure AI Foundry — copy this file to .env and fill in your values

# Your Azure AI Foundry API key (from the deployment page)
AZURE_API_KEY=your-azure-api-key-here

# Your Azure AI Foundry endpoint — use the Target URI from the deployment page
# For Azure AI Foundry serverless deployments it looks like:
#   https://your-deployment.eastus.models.ai.azure.com/v1
# For Azure OpenAI Service it looks like:
#   https://your-resource.openai.azure.com/
AZURE_ENDPOINT=https://your-deployment.eastus.models.ai.azure.com/v1

# The exact deployment name you used in Azure AI Foundry
AZURE_MODEL=gpt-5.3-chat

# API version — required for Azure OpenAI Service; ignored for AI Foundry serverless
AZURE_API_VERSION=2025-01-01-preview
